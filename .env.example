# ═══════════════════════════════════════════════════════════════════════════════
# NeuralBot OMEGA — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────────────────────────
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE
AAVE_BOT_EXECUTOR=0x_YOUR_EXECUTOR_CONTRACT_ADDRESS
VAULT_CONTRACT_ADDRESS=0x_YOUR_VAULT_CONTRACT_ADDRESS
FACTORY_CONTRACT_ADDRESS=0x_YOUR_FACTORY_CONTRACT_ADDRESS
PLATFORM_WALLET=0x_YOUR_PLATFORM_WALLET_ADDRESS

# ── DATABASE (Backend API) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/neuralbot
JWT_SECRET=your_jwt_secret_here_min_32_chars

# ── PAYMENTS ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── OPTIONAL: Intelligence ────────────────────────────────────────────────────
THE_GRAPH_API_KEY=your_graph_api_key
ENABLED_STRATEGIES=liquidation,arb,triangular,mev_backrun,yield,cross_chain,gmx_funding

# ── OPTIONAL: Monitoring ──────────────────────────────────────────────────────
PARTYKIT_URL=wss://grid-bot-server.YOUR_USER.partykit.dev
PARTYKIT_SECRET=your_partykit_secret
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
HUD_PORT=8765
PLATFORM_API_URL=https://your-backend.vercel.app
BOT_API_TOKEN=your_bot_api_token

# ── OPTIONAL: Self-Audit AI (§12 — Claude haiku for anomaly diagnosis) ────────
ANTHROPIC_API_KEY=

# ── OPTIONAL: Keep-Alive (§3 — prevents free tier container sleep) ────────────
PUBLIC_URL=https://your-app.railway.app
SECRET_PROVIDER=env
# SECRET_PROVIDER=doppler
# INFISICAL_TOKEN=your_infisical_token
